<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <h3>Create a new Listing</h3>
    <form action="/listings/<%=listing._id%>?_method=PUT" method="POST">
        <input name="listing[title]" type="text" value="<%=listing.title%>">
        <br/><br/>
        <textarea name="listing[description]"><%=listing.description %></textarea>
        <br/><br/>
        <input type="text" value="<%=listing.image%>" name="listing[image]">
        <br/><br/>
        <input name="listing[price]" type="number" value="<%=listing.price%>">"
        <br/><br/>
        <input name="listing[country]" type="text" value="<%=listing.country%>">
        <br/><br/>
        <input name="listing[location]" type="text" value="<%=listing.location%>">
        <br/><br/>
        <button type="submit">edit</button>
        
    </form>
    
</body>
</html>